{
  "ApplicationSettings": {
    "BaseUrl": "http://localhost:5173/"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.Hosting.Diagnostics": "Information",
      "Microsoft.EntityFrameworkCore": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=afra-app;Username=AfraAppUser;Password=AfraAppPassword;"
  },
  "MigrateOnStartup": true,
  "Oidc": {
    "Enabled": false,
    "Authority": "https://keycloak.example.com/realms/afra",
    "ClientId": "afra-app",
    "ClientSecret": "CHANGE_ME",
    "CallbackPath": "/signin-oidc",
    "SignedOutCallbackPath": "/signout-callback-oidc",
    "UserIdentifierClaim": "email"
  },
  "Certificates": {
    "DataProtectionCert": "../../dev/certs/app.pem",
    "DataProtectionKey": "../../dev/certs/app.key"
  },
  "CookieAuthentication": {
    "CookieTimeout": "21.00:00:00"
  },
  "SMTP": {
    "Host": "localhost",
    "Port": "1025",
    "SecureSocketOptions": "Auto",
    "SenderEmail": "noreply@afra-app",
    "SenderName": "AfraApp"
  },
  "EmergencyBackup": {
    "BaseUri": "http://emergency:8000/",
    "Username": "admin",
    "Password": "admin"
  },
  "General": {
    "Schulleiter": {
      "Vorname": "Annabell",
      "Nachname": "Hecht"
    }
  },
  "Otium": {
    "EnableEmergencyBackup": false,
    "EnrollmentReminder": {
      "Enabled": true,
      "Time": "17:00"
    },
    "StudentMisbehaviourNotification": {
      "Enabled": true,
      "Time": "17:50"
    },
    "MissingStudentsReport": {
      "Enabled": true,
      "Recipients": [
        "m.mustermann@example.com"
      ]
    },
    "Blocks": [
      {
        "Interval": {
          "Start": "13:45",
          "Duration": "01:10"
        },
        "Verpflichtend": true,
        "Bezeichnung": "1. Slot (Otium)",
        "Id": "1",
        "EinschreibenBis": "13:00"
      },
      {
        "Interval": {
          "Start": "15:05",
          "Duration": "01:10"
        },
        "Verpflichtend": true,
        "Bezeichnung": "2. Slot (Otium)",
        "Id": "2",
        "EinschreibenBis": "13:00"
      },
      {
        "Interval": {
          "Start": "16:30",
          "Duration": "01:30"
        },
        "Verpflichtend": false,
        "Bezeichnung": "Profilsport (16:30 Uhr)",
        "Id": "A",
        "EinschreibenBis": "13:00"
      },
      {
        "Interval": {
          "Start": "18:30",
          "Duration": "01:30"
        },
        "Verpflichtend": false,
        "Bezeichnung": "Profilsport (18:30 Uhr)",
        "Id": "B",
        "EinschreibenBis": "13:00"
      },
      {
        "Interval": {
          "Start": "20:00",
          "Duration": "01:30"
        },
        "Verpflichtend": false,
        "Bezeichnung": "Profilsport (20:00 Uhr)",
        "Id": "C",
        "EinschreibenBis": "13:00"
      }
    ]
  },
  "Profundum": {
    "ProfundumBlockiert": {
      "7": [1, 2]
    },
    "deterministicMatching": false,
    "ProfilPflichtigkeit": {
      "9": [3, 4],
      "10": [1, 2]
    },
    "ProfilZulassung": {
      "9a": [1, 2]
    }
  },
  "LDAP": {
    "Enabled": false,
    "Host": "127.0.0.1",
    "Port": 636,
    "ValidateCertificate": false,
    "Username": "",
    "Password": "",
    "GlobalScope": {
      "BaseDN": "dc=sankt-afra,dc=de",
      "Filter": "(objectClass=user)"
    },
    "UserGroups": [
      {
        "Rolle": "Tutor",
        "BaseDn": "ou=Schule,dc=sankt-afra,dc=de",
        "Filter": "(&(objectClass=user)(memberOf=cn=Lehrer,ou=Gruppen,ou=Schule,dc=sankt-afra,dc=de))"
      },
      {
        "Rolle": "Mittelstufe",
        "Group": "7-10",
        "BaseDn": "ou=Schule,dc=sankt-afra,dc=de",
        "Filter": "(&(objectClass=user)(memberOf=CN=Mittelstufe,OU=Gruppen,OU=Schule,DC=sankt-afra,DC=de))"
      },
      {
        "Rolle": "Oberstufe",
        "Group": "11-12",
        "BaseDn": "ou=Schule,dc=sankt-afra,dc=de",
        "Filter": "(&(objectClass=user)(memberOf=CN=Oberstufe,OU=Gruppen,OU=Schule,DC=sankt-afra,DC=de))"
      }
    ],
    "PermissionGroups": [
      {
        "Permission": "Admin",
        "BaseDn": "ou=Schule,dc=sankt-afra,dc=de",
        "Filter": "(&(objectClass=user)(memberOf=cn=Admins,ou=Gruppen,ou=Schule,dc=sankt-afra,dc=de))",
        "ManuallyAssignedUsers": [
          "admin@example.com"
        ]
      },
      {
        "Permission": "Otiumsverantwortlich",
        "BaseDn": "ou=Schule,dc=sankt-afra,dc=de",
        "Filter": "(&(objectClass=user)(memberOf=cn=Otiumsverantwortlich,ou=Gruppen,ou=Schule,dc=sankt-afra,dc=de))",
        "ManuallyAssignedUsers": [
          "otium@example.com"
        ]
      },
      {
        "Permission": "Profundumsverantwortlich",
        "BaseDn": "ou=Schule,dc=sankt-afra,dc=de",
        "Filter": "(&(objectClass=user)(memberOf=cn=Profundumsverantwortlich,ou=Gruppen,ou=Schule,dc=sankt-afra,dc=de))",
        "ManuallyAssignedUsers": [
          "profundum@example.com"
        ]
      }
    ],
    "MentorGroups": [
      {
        "BaseDn": "OU=Mentoren,OU=Afra-Anwendungen,OU=Gruppen,OU=Schule,DC=sankt-afra,DC=de",
        "Filter": "(objectClass=group)",
        "Type": "GM"
      },
      {
        "BaseDn": "OU=Mentoren,OU=Afra-Anwendungen,OU=Gruppen,OU=Schule,DC=sankt-afra,DC=de",
        "Filter": "(objectClass=group)",
        "Type": "IM"
      }
    ]
  },
  "Typst": {
    "TypstResourcePath": "../../storage/img/",
    "TypstFontPaths": ["../../storage/fonts/"],
    "NumThreads": 10
  }
}
